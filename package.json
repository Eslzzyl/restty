{
  "name": "@eslzzyl/restty",
  "version": "0.1.37",
  "description": "Browser terminal rendering library powered by WASM, WebGPU/WebGL2, and TypeScript text shaping.",
  "keywords": [
    "terminal",
    "terminal-emulator",
    "tty",
    "ansi",
    "vt",
    "ghostty",
    "webgpu",
    "webgl2",
    "wasm",
    "text-shaper",
    "text-shaping",
    "unicode",
    "font-shaping",
    "typescript"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/eslzzyl/restty"
  },
  "bugs": {
    "url": "https://github.com/eslzzyl/restty/issues"
  },
  "homepage": "https://github.com/eslzzyl/restty#readme",
  "license": "MIT",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "type": "module",
  "main": "./dist/restty.js",
  "module": "./dist/restty.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/restty.js",
      "default": "./dist/restty.js"
    },
    "./internal": {
      "types": "./dist/internal.d.ts",
      "import": "./dist/internal.js",
      "default": "./dist/internal.js"
    },
    "./xterm": {
      "types": "./dist/xterm.d.ts",
      "import": "./dist/xterm.js",
      "default": "./dist/xterm.js"
    },
    "./esm": {
      "types": "./dist/index.d.ts",
      "import": "./dist/restty.esm.js",
      "default": "./dist/restty.esm.js"
    },
    "./esm/internal": {
      "types": "./dist/internal.d.ts",
      "import": "./dist/internal.esm.js",
      "default": "./dist/internal.esm.js"
    },
    "./esm/xterm": {
      "types": "./dist/xterm.d.ts",
      "import": "./dist/xterm.esm.js",
      "default": "./dist/xterm.esm.js"
    }
  },
  "scripts": {
    "setup:wgpu-polyfill": "tsx scripts/setup-wgpu-polyfill.ts",
    "clean:dist": "rm -rf dist && mkdir -p dist",
    "build:themes": "tsx scripts/generate-builtin-themes.ts",
    "build:wasm": "tsx scripts/build-wasm.ts",
    "build:lib": "vite build",
    "build:esm": "tsx scripts/build-esm.ts",
    "build:types": "tsc -p tsconfig.build.json",
    "build": "tsx scripts/generate-builtin-themes.ts && rm -rf dist && mkdir -p dist && vite build && tsx scripts/build-esm.ts && tsc -p tsconfig.build.json",
    "build:playground-app": "vite build --config vite.playground.config.ts",
    "build:assets": "vite build --config vite.playground.config.ts",
    "check:themes": "tsx scripts/generate-builtin-themes.ts && git diff --exit-code -- src/theme/builtin-themes.ts",
    "lint": "oxlint src playground scripts tests",
    "format:base": "oxfmt src --config .oxfmtrc.json --ignore-path .gitignore --ignore-path .oxfmtignore",
    "format": "oxfmt src --config .oxfmtrc.json --ignore-path .gitignore --ignore-path .oxfmtignore --write",
    "format:check": "oxfmt src --config .oxfmtrc.json --ignore-path .gitignore --ignore-path .oxfmtignore --check",
    "prepublishOnly": "tsx scripts/generate-builtin-themes.ts && rm -rf dist && mkdir -p dist && vite build && tsx scripts/build-esm.ts && tsc -p tsconfig.build.json",
    "test": "vitest run",
    "test:ci": "vitest run --exclude 'tests/webgpu-glyph.test.ts'",
    "test:watch": "vitest",
    "pty": "tsx playground/pty-server.ts",
    "playground": "tsx scripts/playground-dev.ts",
    "playground:static": "vite preview --config vite.playground.config.ts"  },
  "dependencies": {
    "text-shaper": "0.1.22",
    "ws": "^8.21.0",
    "zigpty": "^0.2.0"
  },
  "devDependencies": {
    "@webcontainer/api": "^1.6.1",
    "@webgpu/types": "^0.1.69",
    "oxfmt": "^0.28.0",
    "oxlint": "^1.19.0",
    "tsx": "^4.22.4",
    "typescript": "^5.9.3",
    "vite": "^8.0.0",
    "vitest": "^3.1.0",
    "wgpu-polyfill": "^0.1.0"
  },
  "engines": {
    "node": ">=20.19.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
